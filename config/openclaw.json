{
  "gateway": {
    "mode": "local",
    "port": 18789,
    "bind": "lan",
    "auth": {
      "mode": "password",
      "password": "${OPENCLAW_GATEWAY_PASSWORD}"
    }
  },

  "ui": {
    "assistant": {
      "name": "Orion",
      "avatar": "🌌"
    }
  },

  "agents": {
    "defaults": {
      "workspace": "/root/.openclaw/workspace",
      "model": {
        "primary": "openai/gpt-4o"
      },
      "skills": ["bash", "file-manager"]
    },
    "list": [
      {
        "id": "accountant",
        "agentDir": "/root/.openclaw/workspace/skills/accountant",
        "model": {
          "primary": "openai/gpt-4o"
        },
        "systemPromptOverride": "You are Orion's Accountant agent. Your role: manage invoices, budgets, expense tracking, financial reports, and spreadsheet generation. Always confirm before any financial action. Respond concisely for voice TTS — keep spoken responses under 3 sentences, then offer detail on request."
      },
      {
        "id": "social-manager",
        "agentDir": "/root/.openclaw/workspace/skills/social-manager",
        "model": {
          "primary": "openai/gpt-4o-mini"
        },
        "systemPromptOverride": "You are Orion's Social Media Manager agent. Your role: draft posts, schedule content, analyze engagement, reply to mentions, generate captions and hashtags. Optimise content per platform. Keep voice responses brief and action-oriented."
      },
      {
        "id": "project-manager",
        "agentDir": "/root/.openclaw/workspace/skills/project-manager",
        "model": {
          "primary": "openai/gpt-4o"
        },
        "systemPromptOverride": "You are Orion's Project Manager agent. Your role: manage tasks, timelines, blockers, standup summaries, Slack/Discord updates, and sprint planning. Keep voice summaries to bullet points read aloud."
      }
    ]
  },

  "models": {
    "providers": {
      "openai": {
        "baseUrl": "https://api.openai.com/v1",
        "apiKey": "${OPENAI_API_KEY}",
        "models": [
          {
            "id": "openai/gpt-4o",
            "name": "GPT-4o",
            "api": "openai-completions",
            "reasoning": false,
            "input": ["text", "image"],
            "cost": { "input": 5, "output": 15, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 128000,
            "maxTokens": 4096
          },
          {
            "id": "openai/gpt-4o-mini",
            "name": "GPT-4o Mini",
            "api": "openai-completions",
            "reasoning": false,
            "input": ["text", "image"],
            "cost": { "input": 0.15, "output": 0.6, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 128000,
            "maxTokens": 4096
          }
        ]
      }
    }
  },

  "talk": {
    "provider": "elevenlabs",
    "providers": {
      "elevenlabs": {
        "apiKey": "${ELEVENLABS_API_KEY}"
      }
    }
  },

  "channels": {
    "slack": {
      "botToken": "${SLACK_BOT_TOKEN}"
    },
    "discord": {
      "token": "${DISCORD_BOT_TOKEN}"
    },
    "telegram": {
      "botToken": "${TELEGRAM_BOT_TOKEN}"
    }
  },

  "logging": {
    "level": "info",
    "file": "/tmp/openclaw/openclaw.log"
  }
}
